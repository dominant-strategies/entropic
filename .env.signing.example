# macOS signing / notarization (local only; do not commit real values)
CERT="Developer ID Application: YOUR NAME (TEAMID)"
APPLE_ID="you@appleid.com"
TEAM_ID="TEAMID"
APP_PASSWORD="app-specific-password"

# Optional overrides for signing script
# APP_PATH="/Users/you/nova-build/src-tauri/target/release/bundle/macos/Nova.app"
# DMG_PATH="/Users/you/Nova.dmg"
# ENTITLEMENTS_PATH="/Users/you/nova-build/src-tauri/entitlements.plist"
